// Hint files help the Visual Studio IDE interpret Visual C++ identifiers
// such as names of functions and macros.
// For more information see https://go.microsoft.com/fwlink/?linkid=865984
#define DEFINE_MEMBER(Name, Offset, __VA_ARGS__) __VA_ARGS__ Get##Name() const { return *reinterpret_cast<__VA_ARGS__*>(reinterpret_cast<uintptr_t>(this) + Offset); } void Set##Name(__VA_ARGS__ Value) { *reinterpret_cast<__VA_ARGS__*>(reinterpret_cast<uintptr_t>(this) + Offset) = Value; }
